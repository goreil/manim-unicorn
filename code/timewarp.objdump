main:
    1000:	    call   101b <ret1>
    1005:	    mov    rdi,rax
    1008:	    call   1023 <ret2>
    100d:	    mov    rsi,rax
    1010:	    cmp    rdi,rsi
    1013:	    jne    101a <_end>
    1015:	    call   102b <win>

_end:
    101a:	 	int3   

ret1:
    101b:	 	mov    rax,0xa
    1022:	 	ret    

ret2:
    1023:	 	mov    rax,0x1e
    102a:	 	ret    

win:
    102b:	 	ret    
